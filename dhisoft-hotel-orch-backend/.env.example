NODE_ENV=development
PORT=6006
ENABLE_SWAGGER=true
DATABASE_URL=postgresql://hotel_os:hotel_os@localhost:5432/hotel_os?schema=public
DIRECT_URL=postgresql://hotel_os:hotel_os@localhost:5432/hotel_os?schema=public
TENANT_JWT_SECRET=replace-with-a-long-random-tenant-secret
PLATFORM_JWT_SECRET=replace-with-a-long-random-platform-secret
JWT_EXPIRES_IN=8h
DEFAULT_TENANT_SLUG=rainwood
PLATFORM_BOOTSTRAP_EMAIL=owner@dhisoft.local
PLATFORM_BOOTSTRAP_PASSWORD=replace-with-a-strong-development-password
PLATFORM_BOOTSTRAP_NAME=DHISOFT Platform Owner
# Temporary, explicit owner rotation switch. Disable after the controlled login test.
PLATFORM_BOOTSTRAP_SYNC=false
RAINWOOD_BOOTSTRAP_ACTIVE=false
INTEGRATION_ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
SEED_ADMIN_EMAIL=admin@rainwood.local
SEED_ADMIN_PASSWORD=replace-with-a-strong-development-password
PLATFORM_BASE_DOMAIN=localhost
CORS_ORIGINS=http://localhost:6080,http://127.0.0.1:6080
AXISROOMS_BASE_URL=https://sandbox.example-axisrooms.invalid
AXISROOMS_API_KEY=replace-me
AXISROOMS_WEBHOOK_SECRET=replace-me
AXISROOMS_MODE=mock
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=replace-me
