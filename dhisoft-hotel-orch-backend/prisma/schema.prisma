generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TenantStatus {
  ONBOARDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}
enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  RESERVATION_MANAGER
  RESERVATION_AGENT
  ACCOUNTS
  CONTENT_EDITOR
  VIEWER
}
enum UserStatus {
  ACTIVE
  DISABLED
}

/// Kept only for migration compatibility. Platform operators use PlatformUserRole.
enum PlatformUserRole {
  PLATFORM_OWNER
  SUPER_ADMIN
  SUPPORT_ADMIN
  BILLING_ADMIN
  READ_ONLY_AUDITOR
}

enum PlatformUserStatus {
  ACTIVE
  DISABLED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
  CUSTOM
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum DomainType {
  SUBDOMAIN
  CUSTOM
}

enum DomainStatus {
  PENDING_VERIFICATION
  VERIFIED
  ACTIVE
  FAILED
  DISABLED
}

enum ThemeCatalogueStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
}

enum SupportSessionStatus {
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  REJECTED
  REVOKED
  EXPIRED
}

enum IntegrationHealth {
  UNKNOWN
  HEALTHY
  DEGRADED
  DOWN
}
enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
enum ReservationStatus {
  HOLD
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  EXPIRED
  FAILED
}
enum ReservationSource {
  WEBSITE
  DIRECT
  PHONE
  EMAIL
  WHATSAPP
  AGENT
  COMPANY
  OTA
}
enum PaymentStatus {
  INITIATED
  PENDING
  VERIFIED
  PAID
  FAILED
  PARTIALLY_PAID
  REFUNDED
  VOID
}
enum PaymentMethod {
  GATEWAY
  UPI
  BANK_TRANSFER
  CASH
  COMPANY_CREDIT
  OTHER
}
enum SyncStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  RETRYING
}
enum SyncDirection {
  INBOUND
  OUTBOUND
}
enum IntegrationEntityType {
  PROPERTY
  ROOM_TYPE
  RATE_PLAN
  RESERVATION
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  CLOSED
  SPAM
}

model Tenant {
  id String @id @default(uuid()) @db.Uuid
  name String
  legalName String?
  slug String @unique
  status TenantStatus @default(ONBOARDING)
  companyEmail String?
  companyPhone String?
  timezone String @default("Asia/Kolkata")
  currency String @default("INR")
  onboardingState Json?
  archivedAt DateTime?
  createdByPlatformUserId String? @db.Uuid
  createdByPlatformUser PlatformUser? @relation("TenantCreatedBy", fields:[createdByPlatformUserId], references:[id], onDelete:SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users User[]
  properties Property[]
  themes SiteTheme[]
  pages SitePage[]
  media MediaAsset[]
  offers Offer[]
  guests Guest[]
  reservations Reservation[]
  payments Payment[]
  mappings IntegrationMapping[]
  syncJobs SyncJob[]
  auditLogs AuditLog[]
  enquiries Enquiry[]
  subscriptions TenantSubscription[]
  features TenantFeature[]
  domains TenantDomain[]
  usageSnapshots TenantUsageSnapshot[]
  supportSessions SupportSession[]
  platformAuditLogs PlatformAuditLog[]
  integrationCredentials TenantIntegrationCredential[]
  @@index([status,createdAt])
}

model User {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  email String
  passwordHash String
  name String
  role UserRole
  status UserStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  propertyAccess UserPropertyAccess[]
  approvedSupportSessions SupportSession[] @relation("SupportApprovedBy")
  @@unique([tenantId,email])
  @@index([tenantId,role])
}

model UserPropertyAccess {
  userId String @db.Uuid
  propertyId String @db.Uuid
  user User @relation(fields:[userId], references:[id], onDelete:Cascade)
  property Property @relation(fields:[propertyId], references:[id], onDelete:Cascade)
  @@id([userId,propertyId])
}

model Property {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  name String
  slug String
  destination String
  description String @db.Text
  address String @db.Text
  contactEmail String
  phone String
  timezone String @default("Asia/Kolkata")
  currency String @default("INR")
  taxPercentage Decimal @db.Decimal(5,2) @default(18)
  active Boolean @default(true)
  images Json
  amenities Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roomTypes RoomType[]
  ratePlans RatePlan[]
  inventoryDays InventoryDay[]
  reservations Reservation[]
  reservationRooms ReservationRoom[]
  offers Offer[]
  enquiries Enquiry[]
  propertyAccess UserPropertyAccess[]
  @@unique([tenantId,slug])
  @@index([tenantId,active])
}

model RoomType {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  propertyId String @db.Uuid
  property Property @relation(fields:[propertyId], references:[id], onDelete:Cascade)
  name String
  slug String
  description String @db.Text
  maxAdults Int
  maxChildren Int
  maxOccupancy Int
  baseOccupancy Int @default(2)
  extraAdultRate Decimal @db.Decimal(12,2) @default(0)
  extraChildRate Decimal @db.Decimal(12,2) @default(0)
  inventoryCount Int
  active Boolean @default(true)
  images Json
  amenities Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ratePlans RatePlan[]
  inventoryDays InventoryDay[]
  reservationRooms ReservationRoom[]
  @@unique([propertyId,slug])
  @@index([tenantId,propertyId,active])
}

model RatePlan {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  propertyId String @db.Uuid
  roomTypeId String @db.Uuid
  property Property @relation(fields:[propertyId], references:[id], onDelete:Cascade)
  roomType RoomType @relation(fields:[roomTypeId], references:[id], onDelete:Cascade)
  code String
  name String
  mealPlan String
  baseRate Decimal @db.Decimal(12,2)
  cancellationPolicy Json
  active Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  inventoryDays InventoryDay[]
  reservationRooms ReservationRoom[]
  @@unique([roomTypeId,code])
  @@index([tenantId,propertyId,active])
}

model InventoryDay {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  propertyId String @db.Uuid
  roomTypeId String @db.Uuid
  ratePlanId String @db.Uuid
  property Property @relation(fields:[propertyId], references:[id], onDelete:Cascade)
  roomType RoomType @relation(fields:[roomTypeId], references:[id], onDelete:Cascade)
  ratePlan RatePlan @relation(fields:[ratePlanId], references:[id], onDelete:Cascade)
  date DateTime @db.Date
  availableRooms Int
  rate Decimal @db.Decimal(12,2)
  stopSell Boolean @default(false)
  closedToArrival Boolean @default(false)
  closedToDeparture Boolean @default(false)
  minLengthOfStay Int @default(1)
  version Int @default(0)
  source String @default("LOCAL")
  updatedAt DateTime @updatedAt
  @@unique([ratePlanId,date])
  @@index([tenantId,propertyId,date])
  @@index([roomTypeId,date])
}

model SiteTheme {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  catalogueThemeId String? @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  catalogueTheme ThemeCatalogue? @relation(fields:[catalogueThemeId], references:[id], onDelete:SetNull)
  name String
  key String
  config Json
  active Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  pages SitePage[]
  @@unique([tenantId,key])
  @@index([catalogueThemeId])
}

model SitePage {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  themeId String? @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  theme SiteTheme? @relation(fields:[themeId], references:[id], onDelete:SetNull)
  title String
  slug String
  status PageStatus @default(DRAFT)
  draftContent Json
  publishedContent Json?
  seo Json
  navigation Json
  publishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  versions SitePageVersion[]
  @@unique([tenantId,slug])
  @@index([tenantId,status])
}

model SitePageVersion {
  id String @id @default(uuid()) @db.Uuid
  pageId String @db.Uuid
  page SitePage @relation(fields:[pageId], references:[id], onDelete:Cascade)
  version Int
  content Json
  createdById String? @db.Uuid
  createdAt DateTime @default(now())
  @@unique([pageId,version])
}

model MediaAsset {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  filename String
  url String
  mimeType String
  sizeBytes Int
  altText String?
  createdAt DateTime @default(now())
  @@index([tenantId,createdAt])
}

model Offer {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  propertyId String? @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  property Property? @relation(fields:[propertyId], references:[id], onDelete:Cascade)
  title String
  slug String
  description String @db.Text
  imageUrl String?
  discountType String
  discountValue Decimal @db.Decimal(12,2)
  promoCode String?
  bookingStart DateTime?
  bookingEnd DateTime?
  stayStart DateTime?
  stayEnd DateTime?
  blackoutDates Json
  terms Json
  active Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId,slug])
}

model Guest {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  firstName String
  lastName String
  email String
  mobile String
  country String @default("IN")
  address String?
  gstin String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reservations Reservation[]
  @@index([tenantId,email])
  @@index([tenantId,mobile])
}

model Reservation {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  propertyId String @db.Uuid
  guestId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  property Property @relation(fields:[propertyId], references:[id])
  guest Guest @relation(fields:[guestId], references:[id])
  bookingRef String
  status ReservationStatus @default(HOLD)
  source ReservationSource
  externalSourceRef String?
  currency String @default("INR")
  roomSubtotal Decimal @db.Decimal(12,2)
  taxTotal Decimal @db.Decimal(12,2)
  discountTotal Decimal @db.Decimal(12,2) @default(0)
  grandTotal Decimal @db.Decimal(12,2)
  paidTotal Decimal @db.Decimal(12,2) @default(0)
  balanceTotal Decimal @db.Decimal(12,2)
  holdExpiresAt DateTime?
  specialRequest String? @db.Text
  internalNotes String? @db.Text
  cancellationReason String? @db.Text
  confirmedAt DateTime?
  cancelledAt DateTime?
  createdById String? @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rooms ReservationRoom[]
  payments Payment[]
  syncJobs SyncJob[]
  @@unique([tenantId,bookingRef])
  @@index([tenantId,propertyId,status,createdAt])
  @@index([tenantId,holdExpiresAt])
}

model ReservationRoom {
  id String @id @default(uuid()) @db.Uuid
  reservationId String @db.Uuid
  propertyId String @db.Uuid
  roomTypeId String @db.Uuid
  ratePlanId String @db.Uuid
  reservation Reservation @relation(fields:[reservationId], references:[id], onDelete:Cascade)
  property Property @relation(fields:[propertyId], references:[id])
  roomType RoomType @relation(fields:[roomTypeId], references:[id])
  ratePlan RatePlan @relation(fields:[ratePlanId], references:[id])
  checkIn DateTime @db.Date
  checkOut DateTime @db.Date
  quantity Int
  adults Int
  children Int
  nightlyBreakdown Json
  subtotal Decimal @db.Decimal(12,2)
  @@index([reservationId])
}

model Payment {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  reservationId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  reservation Reservation @relation(fields:[reservationId], references:[id], onDelete:Cascade)
  amount Decimal @db.Decimal(12,2)
  currency String @default("INR")
  method PaymentMethod
  status PaymentStatus @default(INITIATED)
  provider String
  providerReference String?
  idempotencyKey String
  proofUrl String?
  notes String?
  verifiedById String? @db.Uuid
  verifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  events PaymentEvent[]
  @@index([tenantId,reservationId,status])
  @@unique([tenantId,idempotencyKey])
}

model PaymentEvent {
  id String @id @default(uuid()) @db.Uuid
  paymentId String @db.Uuid
  payment Payment @relation(fields:[paymentId], references:[id], onDelete:Cascade)
  providerEventId String @unique
  payload Json
  createdAt DateTime @default(now())
}

model IntegrationMapping {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  provider String
  entityType IntegrationEntityType
  internalId String
  externalId String
  metadata Json
  active Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId,provider,entityType,internalId])
  @@unique([tenantId,provider,entityType,externalId])
}

model SyncJob {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  reservationId String? @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  reservation Reservation? @relation(fields:[reservationId], references:[id], onDelete:SetNull)
  provider String
  direction SyncDirection
  operation String
  status SyncStatus @default(PENDING)
  payload Json
  response Json?
  attemptCount Int @default(0)
  nextAttemptAt DateTime?
  lastError String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId,status,nextAttemptAt])
}

model AuditLog {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  actorUserId String? @db.Uuid
  action String
  entityType String
  entityId String
  before Json?
  after Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  @@index([tenantId,entityType,entityId,createdAt])
}


model Enquiry {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  propertyId String? @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  property Property? @relation(fields:[propertyId], references:[id], onDelete:SetNull)
  type String
  name String
  email String
  phone String?
  message String @db.Text
  status EnquiryStatus @default(NEW)
  sourcePage String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId,status,createdAt])
}

model PlatformUser {
  id String @id @default(uuid()) @db.Uuid
  email String @unique
  passwordHash String
  name String
  role PlatformUserRole
  status PlatformUserStatus @default(ACTIVE)
  mfaRequired Boolean @default(true)
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdTenants Tenant[] @relation("TenantCreatedBy")
  requestedSupportSessions SupportSession[] @relation("SupportRequestedBy")
  auditLogs PlatformAuditLog[] @relation("PlatformAuditActor")
  @@index([role,status])
}

model SubscriptionPlan {
  id String @id @default(uuid()) @db.Uuid
  code String @unique
  name String
  description String?
  billingInterval BillingInterval
  monthlyPrice Decimal? @db.Decimal(12,2)
  annualPrice Decimal? @db.Decimal(12,2)
  setupFee Decimal @db.Decimal(12,2) @default(0)
  currency String @default("INR")
  limits Json
  features Json
  active Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subscriptions TenantSubscription[]
}

model TenantSubscription {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  planId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  plan SubscriptionPlan @relation(fields:[planId], references:[id], onDelete:Restrict)
  status SubscriptionStatus
  startsAt DateTime
  trialEndsAt DateTime?
  currentPeriodEndsAt DateTime?
  cancelledAt DateTime?
  autoRenew Boolean @default(true)
  commercialTerms Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId,status])
  @@index([status,currentPeriodEndsAt])
}

model FeatureDefinition {
  id String @id @default(uuid()) @db.Uuid
  key String @unique
  name String
  description String?
  defaultEnabled Boolean @default(false)
  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantFeatures TenantFeature[]
}

model TenantFeature {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  featureId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  feature FeatureDefinition @relation(fields:[featureId], references:[id], onDelete:Cascade)
  enabled Boolean
  config Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId,featureId])
  @@index([tenantId,enabled])
}

model TenantDomain {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  domain String @unique
  type DomainType
  status DomainStatus @default(PENDING_VERIFICATION)
  verificationToken String @unique
  primary Boolean @default(false)
  verifiedAt DateTime?
  sslStatus String @default("PENDING")
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId,status])
}

model ThemeCatalogue {
  id String @id @default(uuid()) @db.Uuid
  key String
  version Int
  name String
  description String?
  status ThemeCatalogueStatus @default(DRAFT)
  config Json
  sectionSchema Json
  previewUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantThemes SiteTheme[]
  @@unique([key,version])
  @@index([status,updatedAt])
}

model TenantUsageSnapshot {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  periodStart DateTime
  periodEnd DateTime
  properties Int @default(0)
  activeUsers Int @default(0)
  reservations Int @default(0)
  bookingValue Decimal @db.Decimal(14,2) @default(0)
  storageBytes BigInt @default(0)
  apiRequests BigInt @default(0)
  createdAt DateTime @default(now())
  @@unique([tenantId,periodStart,periodEnd])
  @@index([periodEnd])
}

model SupportSession {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  requestedById String @db.Uuid
  approvedByTenantUserId String? @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  requestedBy PlatformUser @relation("SupportRequestedBy", fields:[requestedById], references:[id], onDelete:Cascade)
  approvedByTenantUser User? @relation("SupportApprovedBy", fields:[approvedByTenantUserId], references:[id], onDelete:SetNull)
  status SupportSessionStatus @default(PENDING_APPROVAL)
  reason String @db.Text
  requiresTenantApproval Boolean @default(true)
  approvedAt DateTime?
  activatedAt DateTime?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId,status,expiresAt])
  @@index([requestedById,status])
}

model PlatformAuditLog {
  id String @id @default(uuid()) @db.Uuid
  actorPlatformUserId String? @db.Uuid
  tenantId String? @db.Uuid
  actor PlatformUser? @relation("PlatformAuditActor", fields:[actorPlatformUserId], references:[id], onDelete:SetNull)
  tenant Tenant? @relation(fields:[tenantId], references:[id], onDelete:SetNull)
  actorEmail String?
  action String
  entityType String
  entityId String
  metadata Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  @@index([createdAt])
  @@index([tenantId,createdAt])
  @@index([entityType,entityId,createdAt])
}

model PlatformIntegrationProvider {
  id String @id @default(uuid()) @db.Uuid
  key String @unique
  name String
  category String
  enabled Boolean @default(false)
  publicConfig Json?
  health IntegrationHealth @default(UNKNOWN)
  lastCheckedAt DateTime?
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantCredentials TenantIntegrationCredential[]
}

model TenantIntegrationCredential {
  id String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  providerId String @db.Uuid
  tenant Tenant @relation(fields:[tenantId], references:[id], onDelete:Cascade)
  provider PlatformIntegrationProvider @relation(fields:[providerId], references:[id], onDelete:Cascade)
  encryptedConfig String @db.Text
  enabled Boolean @default(true)
  health IntegrationHealth @default(UNKNOWN)
  lastTestedAt DateTime?
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId,providerId])
  @@index([tenantId,enabled])
}


